    <string name="setting_title_cookie">Cookies</string>
    <string name="setting_summary_cookie_delete">Als je dit inschakelt, dan worden alle cookies verwijderd, óók de cookies van vertrouwde websites.</string>
    <string name="setting_summary_cookie">Cookies inschakelen. Cookies zijn kleine tekstbestanden die worden opgeslagen op je apparaat. Websites
    gebruiken die om bijv. je gebruikersinstellingen op te slaan (zoals je zoekinstellingen). Maar ze kunnen ook worden gebruikt om
        persoonlijke gegevens te verzamelen. Cookies van derde partijen (die persoonlijke gegevens verzamelen voor reclamedoeleinden) zijn altijd uitgeschakeld.</string>
    <string name="setting_title_whitelistCookie">Witte lijst</string>
    <string name="setting_summary_whitelistCookie">Als je cookies uitschakelt, dan kun je deze witte lijst gebruiken om websites die je
        vertrouwt cookies te laten opslaan.</string>
    <string name="setting_title_javascript">JavaScript</string>
    <string name="setting_summary_javascript">JavaScript inschakelen. Veel websites gebruiken JavaScript voor functionaliteit (menu\'s\',
        het laden en tonen van afbeeldingen, etc.). Maar JavaScript is ook risicovol en kan worden gebruikt voor aanvallen.</string>
    <string name="setting_title_whitelistJS">Wite lijst</string>
    <string name="setting_summary_whitelistJS">Als je JavaScript uitschakelt, dan kun je deze witte lijst gebruiken om websites die je
        vertrouwt JavaScript te laten gebruiken.</string>
    <string name="setting_title_adblock">Advertentieblokkering</string>
    <string name="setting_summary_adblock">Schakel advertentieblokkering in om vervelende reclame te blokkeren. Websites laden hierdoor ook sneller.</string>
    <string name="setting_title_whitelist">Wiite lijst</string>
    <string name="setting_summary_whitelist">Laat deze websites reclame tonen. Sommige sites werken niet als advertentieblokkering is ingeschakeld.</string>
