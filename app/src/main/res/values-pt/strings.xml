    <string name="setting_title_adblock">AdBlock</string>
    <string name="setting_summary_adblock">Ativar AdBlock para bloquear os anúncios. Se ativa, os sites são carregados mais rapidamente.</string>
    <string name="setting_title_whitelist">Anúncios permitidos</string>
    <string name="setting_summary_whitelist">Permitir que estes sites mostrem anúncios. Alguns sites não funcionam se AdBlock estiver ativado.</string>
