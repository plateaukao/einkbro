    <string name="setting_summary_font_size">Modificare la dimensione dei caratteri per la visualizzazione dei siti Web.</string>
    <string name="setting_title_remote">Contenuti remoti</string>
    <string name="setting_summary_remote">Abilita i contenuti remoti, che non provengono direttamente dal sito web che stai visitando. La disattivazione è più sicura, più rapida e consente di risparmiare volume di dati. Ma alcuni contenuti non saranno più visualizzati.</string>
    <string name="setting_title_save_data">Richiedi \'Salva dati\'</string>
    <string name="setting_summary_save_data">Indica ai siti web che preferisci salvare i dati. I siti web supportati caricheranno più velocemente.</string>
    <!-- browser start -->
    <string name="setting_title_images">Immagini</string>
    <string name="setting_summary_images">Abilita immagini di rete. La disabilitazione potrebbe essere utile per salvare i dati del cellulare e per caricare più velocemente i siti web.</string>
    <string name="setting_title_cookie">Cookies</string>
    <string name="setting_summary_cookie_delete">Se attivata, tutti i cookie verranno eliminati. Anche i cookie di siti web di fiducia.</string>
    <string name="setting_summary_cookie">Abilita i cookie. I cookie sono piccoli file di testo che vengono memorizzati sul dispositivo. I siti web li utilizzano per memorizzare le impostazioni utente (ad esempio, le impostazioni di ricerca). Ma potrebbero anche essere utilizzati per raccogliere dati personali degli utenti. I cookie di terze parti (raccolgono dati utente per la pubblicità) sono sempre disabilitati.</string>
    <string name="setting_title_whitelistCookie">Whitelist cookie</string>
    <string name="setting_summary_whitelistCookie">Se si disattivano i cookie, è possibile utilizzare questa whitelist per consentire ai siti di cui ci si fida di utilizzare i cookie.</string>
    <string name="setting_title_javascript">JavaScript</string>
    <string name="setting_summary_javascript">Abilita JavaScript. Molti siti web hanno bisogno di JavaScript per le loro funzionalità (menu, caricamento e visualizzazione di immagini, …). Ma sono anche un rischio e possono essere utilizzati per attacchi.</string>
    <string name="setting_title_whitelistJS">Whitelist javaScript</string>
    <string name="setting_summary_whitelistJS">Se si disabilita JavaScript, è possibile utilizzare questa whitelist per consentire ai siti di cui ci si fida di utilizzare javascript.</string>
    <string name="setting_title_adblock">AdBlock</string>
    <string name="setting_summary_adblock">Abilita AdBlock per bloccare gli annunci fastidiosi. I siti si caricano anche più velocemente quando il blocco è abilitato.</string>
    <string name="setting_title_whitelist">Whitelist AdBlock</string>
    <string name="setting_summary_whitelist">Consentire a questi siti di mostrare gli annunci. Alcuni siti non funzionano se AdBlock è abilitato.</string>
    <string name="setting_title_location">Posizione</string>
    <string name="setting_summary_location">Permetti ai siti web di accedere alla tua posizione. Alcuni siti web (come Google maps per la navigazione) hanno bisogno di questa funzione.</string>
    <string name="setting_title_history">Cronologia</string>
    <string name="setting_summary_history">Salva la cronologia dei site web visitati.</string>
    <!-- browser clear -->
