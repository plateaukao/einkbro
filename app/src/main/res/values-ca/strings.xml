    <string name="setting_title_images">Imatges</string>
    <string name="setting_summary_images">Activar imatges de xarxa. Desactivar-ho pot ser útil per estalviar dades mòbils i carregar llocs web més ràpid.</string>
    <string name="setting_title_cookie">Cookies</string>
    <string name="setting_summary_cookie_delete">Si s\'activa, totes les cookies s\'eliminaran. També les cookies de llocs de confiança.</string>
    <string name="setting_summary_cookie">Activar cookies. Les cookies són petits fitxers de text emmagatzemats al dispositiu. Els llocs web les utilitzen per desar configuracions d\'usuari (per exemple, opcions de cerca). Però també es poden utilitzar per recopilar dades personals. Les cookies de tercers (recopilen dades per a publicitat) estan sempre desactivades.</string>
    <string name="setting_title_whitelistCookie">Llista blanca de cookies</string>
    <string name="setting_summary_whitelistCookie">Si heu desactivat les cookies, podeu utilitzar aquesta llista blanca per permetre que els llocs de confiança desin cookies.</string>
    <string name="setting_title_javascript">JavaScript</string>
    <string name="setting_summary_javascript">Activar JavaScript. Molts llocs web necessiten JavaScript per a la seva funcionalitat (menús, càrrega i visualització d\'imatges...). Però també són un risc i es poden utilitzar per a atacs.</string>
    <string name="setting_title_whitelistJS">Llista blanca de JavaScript</string>
    <string name="setting_summary_whitelistJS">Si heu desactivat JavaScript, podeu utilitzar aquesta llista blanca per permetre que els llocs de confiança utilitzin JavaScript.</string>
    <string name="setting_title_adblock">AdBlock</string>
    <string name="setting_summary_adblock">Activar AdBlock per bloquejar anuncis molestos. Els llocs es carreguen més ràpid quan està activat.</string>
    <string name="setting_title_whitelist">Llista blanca d\'AdBlock</string>
    <string name="setting_summary_whitelist">Permetre que aquests llocs mostrin anuncis. Alguns llocs no funcionen si AdBlock està activat.</string>
    <string name="setting_title_location">Ubicació</string>
    <string name="setting_summary_location">Permetre que els llocs web accedeixin a la vostra ubicació. Alguns llocs (com Google Maps per a navegació) ho necessiten activat.</string>
    <string name="setting_title_history">Historial</string>
    <string name="setting_summary_history">Desar l\'historial de llocs web visitats.</string>
    <!-- browser clear -->
    <string name="data_summary">Tots els fitxers s\'exportaran al directori \"Android/data/info.plateaukao.einkbro/files/browser_backup/\" de la targeta SD. Aquest directori s\'ELIMINARÀ si desinstal·leu EinkBro. Feu còpies de seguretat regularment en un lloc segur.</string>
