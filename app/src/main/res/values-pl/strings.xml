    <string name="setting_title_images">Grafiki</string>
    <string name="setting_summary_images">Zezwól na ładowanie obrazków. Wyłączenie tej opcji zaoszczędzi dane i poprawi prędkość ładowania.</string>
    <string name="setting_title_cookie">Ciasteczka</string>
    <string name="setting_summary_cookie_delete">Wszystkie ciasteczka zostaną usunięte, także te z witryn zaufanych.</string>
    <string name="setting_summary_cookie">Zezwól na ciasteczka, czyli małe pliki tekstowe zachowywane na twoim urządzeniu. Witryny internetowe zachowują tam twoje preferencje (tj. filtry wyszukiwania). Mogą jednak zapisywać także różne dane osobiste. Ciasteczka od podmiotów trzecich (wykorzystywane do wyświetlania reklam) są wyłączone na stałe.</string>
    <string name="setting_title_whitelistCookie">Biała lista ciasteczek</string>
    <string name="setting_summary_whitelistCookie">Jeśli odrzucisz ogólną zgodę na ciasteczka, możesz dodać do listy te witryny, którym ufasz i które mogą przetrzymywać twoje informacje.</string>
    <string name="setting_title_javascript">JavaScript</string>
    <string name="setting_summary_javascript">Zezwól na skrypty. Wiele witryn wykorzystuje je w ramach swojej funkcjonalności (rozwijane menu, ładowanie obrazków i elementów nawigacyjnych), jednak skrypty te podatne są na ataki.</string>
    <string name="setting_title_whitelistJS">Biała lista JavaScript</string>
    <string name="setting_summary_whitelistJS">Jeśli odrzucisz ogólną zgodę na skrypty, możesz dodać do listy te witryny, którym ufasz i które mogą używać skryptów java.</string>
    <string name="setting_title_adblock">AdBlock</string>
    <string name="setting_summary_adblock">Zezwól na AdBlock do blokady irytujących reklam. Poprawia on prędkość ładowania witryn.</string>
    <string name="setting_title_whitelist">Biała lista AdBlock</string>
    <string name="setting_summary_whitelist">Wprowadź adresy stron, które mogą wyświetlać ci reklamy.</string>
    <string name="setting_title_location">Lokalizacja</string>
    <string name="setting_summary_location">Zezwól na dostęp do lokalizacji twojego urządzenia. Niektóre witryny (np. Google Maps do nawigacji) wymagają włączenia tej funkcji.</string>
    <string name="setting_title_history">Historia</string>
    <string name="setting_summary_history">Zezwól na zapisywanie historii odwiedzanych witryn.</string>
